# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dclaw_fleet
APP_ENV=dev
DEBUG=true

# DB connection pool (defaults shown; raise pool size for higher concurrency,
# but keep pool_size + max_overflow under Postgres max_connections)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Response cache for GET endpoints (in-process TTL; shields DB from repeat reads)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=30

# Per-IP rate limiting (requests/min). Auth endpoints limited separately.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5

# AI — Fleet Copilot uses Ollama. Leave OLLAMA_URL blank to fall back to
# the rule-based responder. For docker compose, use host.docker.internal.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin seeded by Alembic 0004 (CHANGE THE PASSWORD ON FIRST LOGIN)
# Email:    admin@dclaw.io
# Password: admin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8139
